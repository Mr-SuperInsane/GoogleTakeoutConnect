{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Google Takeout Connect デフォルト権限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-ask",
    "dialog:allow-message",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "shell:allow-execute",
    "shell:allow-open"
  ]
}
