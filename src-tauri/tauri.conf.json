{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Google Takeout Connect",
  "version": "0.1.0",
  "identifier": "com.googletakeoutconnect.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Google Takeout Connect",
        "width": 860,
        "height": 680,
        "minWidth": 600,
        "minHeight": 500,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/exiftool",
      "binaries/ffmpeg"
    ],
    "windows": {
      "wix": {
        "language": "ja-JP"
      },
      "allowDowngrades": true
    },
    "publisher": "Google Takeout Connect",
    "copyright": "Copyright © 2025 Google Takeout Connect",
    "shortDescription": "Google Takeoutの写真・動画メタデータを復元するツール",
    "longDescription": "Google Takeoutでエクスポートした写真・動画ファイルに、撮影日時などのメタデータを書き戻すデスクトップアプリです。"
  }
}
